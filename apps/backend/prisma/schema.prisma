// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  password  String
  profile   UserProfile?
  meals     Meal[]
  mealPlans MealPlan[]
  progress  Progress[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  currentStreak Int       @default(0)
  lastStreakAt  DateTime?

  @@map("users")
}

model UserProfile {
  id            String        @id @default(uuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName     String?
  lastName      String?
  age           Int?
  gender        String?
  height        Float?        // in cm
  weight        Float?        // in kg
  activityLevel ActivityLevel?
  goal          Goal?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  targetCalories Float?    // Thêm trường này
  targetProtein  Float?    // Thêm trường này
  targetCarbs    Float?    // Thêm trường này
  targetFat      Float?    // Thêm trường này
  jobNature      JobNature?    
  eatingHabits   EatingHabit[] 
  cookingSkill   CookingSkill?
  isSurveyCompleted Boolean @default(false)

  @@map("user_profiles")
}
enum JobNature {
  SEDENTARY       // Ngồi nhiều (Văn phòng, Coder)
  MODERATE_STANCE // Đứng/Đi lại vừa phải (Bán hàng, giáo viên)
  HEAVY_LABOR     // Lao động nặng (Shipper, Vận động viên)
}

enum EatingHabit {
  SKIP_BREAKFAST // Hay bỏ bữa sáng
  NIGHT_SNACKER  // Hay ăn vặt đêm muộn
  SWEET_TOOTH    // Thèm ngọt, trà sữa
  BALANCED       // Ăn uống quy củ, kỷ luật
}

enum CookingSkill {
  EAT_OUT        // Ăn ngoài tiệm 100%
  OCCASIONAL     // Nửa này nửa nọ (Bữa nấu bữa tiệm)
  MEAL_PREP      // Tự nấu hoàn toàn
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
  EXTRA_ACTIVE
}

enum Goal {
  LOSE_WEIGHT
  MAINTAIN_WEIGHT
  GAIN_WEIGHT
  BUILD_MUSCLE
}

model Meal {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  type           MealType
  foods          Json     // Array of FoodItem
  totalCalories  Float
  totalProtein   Float
  totalCarbs     Float
  totalFat       Float
  imageUrl       String?
  consumedAt     DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("meals")
  @@index([userId, consumedAt])
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model MealPlan {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  startDate     DateTime
  endDate       DateTime
  dailyCalories Float
  dailyMacros   Json     // MacroDistribution
  meals         Json     // Array of PlannedMeal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("meal_plans")
  @@index([userId])
}

model Progress {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime
  weight          Float?
  caloriesConsumed Float
  proteinConsumed  Float
  carbsConsumed    Float
  fatConsumed      Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("progress")
  @@unique([userId, date])
  @@index([userId, date])
}

model FoodLibrary {
  id          String   @id @default(uuid())
  name        String   @unique // Tên món ăn (để tìm kiếm)
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  servingSize    String   @default("Gram") // Ví dụ: Gram, Tô, Dĩa, Suất
  defaultWeight  Float    @default(100)
  isVerified  Boolean  @default(false) // Món do admin xác nhận hoặc do user đóng góp
  createdAt   DateTime @default(now())
}